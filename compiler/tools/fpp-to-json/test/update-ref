#!/bin/bash

. ../../../scripts/test-utils.sh

fpp_to_json=../../../bin/fpp-to-json

update_inner()
{
  args=$1
  infile=$2
  outfile=$3
  echo "updating $outfile.ref.txt"
  $fpp_to_json $infile.fpp $args 2>&1 | remove_path_prefix > $outfile.ref.txt
  
  remove_fpp_version < fpp-ast.json | remove_path_prefix >> $outfile.ref.txt
  remove_fpp_version < fpp-loc-map.json | remove_path_prefix >> $outfile.ref.txt

  if [[ "$args" == *"-s"* ]]; then
    rm fpp-ast.json fpp-loc-map.json
  
  else
    remove_fpp_version < fpp-analysis.json | remove_path_prefix >> $outfile.ref.txt
    # Delete the JSON files
    rm fpp-ast.json fpp-loc-map.json fpp-analysis.json
  fi
}

update(){
  args=$1
  infile=$2
  if test -n "$3"
  then
    outfile=$3
  else
    outfile=$infile
  fi

  update_inner "$args -f" $infile $outfile
}

update_no_format()
{
  args=$1
  infile=$2
  if test -n "$3"
  then
    outfile=$3
  else
    outfile=$infile
  fi

  update_inner "$args" $infile $outfile
}

for file in `find . -name '*.ref.txt'`
do
  rm $file
done

update "" ../../fpp-to-dict/test/top/config frameworkDefs
update "" ../../fpp-syntax/test/state-machine stateMachine
update "" activeComponents
update "" commands
update_no_format "" commands commands_no_format
update "" constTypesComponents
update "" constants
update "" dataProducts
update "" enums
update "" events
update "" importedTopologies
update "" interfaces
update "" internalPorts
update "" matchedPorts
update "" modules
update "" parameters
update "" passiveComponent
update "" ports
update "" queuedComponents
update "" simpleComponents
update "" simpleTopology
update "" specialPorts
update "" telemetry
update "" telemetryPackets
update "" types
update "-s" syntaxOnly
update "fprime/defs.fpp" patternedConnections

